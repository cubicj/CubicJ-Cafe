# CubicJ Cafe — Environment Variables
# Copy to ecosystem.config.js env section (primary) or .env.local (dev override)
# Run `node validate-env.js` to check configuration

# ── Core ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Discord OAuth2 ────────────────────────────────────
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
NEXT_PUBLIC_DISCORD_CLIENT_ID=your-discord-client-id

# ── Discord Bot ───────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_CHANNEL_ID=your-channel-id
DISCORD_NSFW_CHANNEL_ID=your-nsfw-channel-id

# ── ComfyUI ───────────────────────────────────────────
COMFYUI_API_URL=http://127.0.0.1:8188
COMFYUI_RUNPOD_URLS=

# ── Database ──────────────────────────────────────────
DATABASE_URL=file:./prisma/dev.db

# ── Admin ─────────────────────────────────────────────
ADMIN_DISCORD_IDS=your-discord-user-id
NEXT_PUBLIC_ADMIN_DISCORD_IDS=your-discord-user-id

# ── File Upload ───────────────────────────────────────
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ── Translation (optional) ────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Logging (optional) ────────────────────────────────
LOG_DIR=./logs
DEBUG=

# ── Production Only ───────────────────────────────────
# NODE_OPTIONS=--max-old-space-size=2048
# UV_THREADPOOL_SIZE=4
# ALLOWED_ORIGINS=https://your-domain.com
# MAX_CONCURRENT_GENERATIONS=2
# HEALTH_CHECK_INTERVAL=60000
