# CubicJ Cafe — Environment Variables
# Copy to .env and fill in your values
# Run `node validate-env.js` to check configuration

# ── Core ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ── Discord OAuth2 ────────────────────────────────────
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
NEXT_PUBLIC_DISCORD_CLIENT_ID=your-discord-client-id

# ── Discord Bot ───────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_CHANNEL_ID=your-channel-id
DISCORD_NSFW_CHANNEL_ID=your-nsfw-channel-id

# ── ComfyUI ───────────────────────────────────────────
COMFYUI_API_URL=http://127.0.0.1:8188
COMFYUI_RUNPOD_URLS=

# ── Database ──────────────────────────────────────────
DATABASE_URL=file:./prisma/dev.db

# ── Admin ─────────────────────────────────────────────
ADMIN_DISCORD_IDS=your-discord-user-id

# ── File Upload ───────────────────────────────────────
UPLOAD_MAX_SIZE=10485760
UPLOAD_TEMP_DIR=./public/temp

# ── Logging (optional) ────────────────────────────────
LOG_DIR=./logs
LOG_LEVEL=info

# ── Production Only ───────────────────────────────────
# NODE_OPTIONS=--max-old-space-size=2048
# UV_THREADPOOL_SIZE=4
